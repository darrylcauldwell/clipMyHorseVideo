default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    asc_key_id = ENV.fetch("ASC_KEY_ID")
    asc_issuer_id = ENV.fetch("ASC_ISSUER_ID")
    asc_key_path = ENV.fetch("ASC_KEY_PATH")

    api_key = app_store_connect_api_key(
      key_id: asc_key_id,
      issuer_id: asc_issuer_id,
      key_filepath: asc_key_path,
      in_house: false
    )

    begin
      build_number = latest_testflight_build_number(api_key: api_key) + 1
    rescue => e
      UI.message("No existing builds found, starting at 1: #{e.message}")
      build_number = 1
    end

    increment_build_number(
      build_number: build_number,
      xcodeproj: "clipMyHorseVideo.xcodeproj"
    )

    build_app(
      project: "clipMyHorseVideo.xcodeproj",
      scheme: "clipMyHorseVideo",
      export_method: "app-store",
      clean: true,
      destination: "generic/platform=iOS",
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{File.expand_path(asc_key_path)}' -authenticationKeyID #{asc_key_id} -authenticationKeyIssuerID #{asc_issuer_id}",
      export_options: {
        signingStyle: "automatic",
        teamID: "N6BK2WX94Z"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true
    )
  end
end
